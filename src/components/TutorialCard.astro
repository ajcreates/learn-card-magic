---
interface Props {
  id: string;
  title: string;
  description: string;
  tags: string[];
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  slug: string;
}
const { id, title, description, tags, difficulty, slug } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a href={`${BASE}/tutorials/${slug}`} class="card group flex flex-col h-full p-6 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
  <div class="flex items-start justify-between mb-3 gap-3">
    <h3 class="font-display text-lg font-bold text-white group-hover:text-brand-500 transition-colors leading-tight">{title}</h3>
    <span class={`tag tag-difficulty-${difficulty} shrink-0 capitalize text-xs`}>{difficulty}</span>
  </div>
  <p class="text-gray-400 text-sm flex-1 leading-relaxed">{description}</p>
  <div class="flex flex-wrap gap-1 mt-4">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
  <div class="mt-4 text-brand-500 text-sm font-medium group-hover:gap-2 flex items-center gap-1 transition-all">
    Learn this trick →
  </div>
</a>
