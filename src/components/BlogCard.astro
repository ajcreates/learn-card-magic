---
interface Props {
  title: string;
  description: string;
  tags: string[];
  publishedAt: string;
  slug: string;
  readTime?: number;
}
const { title, description, tags, publishedAt, slug, readTime } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const formattedDate = new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={`${BASE}/blog/${slug}`} class="card group flex flex-col h-full p-6 hover:shadow-lg hover:shadow-brand-500/10 transition-all">
  <div class="flex flex-wrap gap-1 mb-3">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
  <h3 class="font-display text-lg font-bold text-white group-hover:text-brand-500 transition-colors leading-tight mb-2">{title}</h3>
  <p class="text-gray-400 text-sm flex-1 leading-relaxed line-clamp-3">{description}</p>
  <div class="flex items-center justify-between mt-4 text-xs text-gray-500">
    <time datetime={publishedAt}>{formattedDate}</time>
    {readTime && <span>{readTime} min read</span>}
  </div>
  <div class="mt-3 text-brand-500 text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all">
    Read more →
  </div>
</a>
