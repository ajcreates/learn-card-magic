---
interface Props {
  youtubeId: string;
  title: string;
  description: string;
  tags: string[];
  difficulty?: string;
  viewCount?: number;
  publishedAt: string;
  slug: string;
}
const { youtubeId, title, description, tags, difficulty, viewCount, publishedAt, slug } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const thumb = `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`;
const formattedViews = viewCount ? new Intl.NumberFormat().format(viewCount) : null;
const formattedDate = new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`${BASE}/videos/${slug}`} class="card group flex flex-col h-full hover:shadow-lg hover:shadow-brand-500/10 transition-all">
  <div class="relative overflow-hidden aspect-video bg-dark-700">
    <img
      src={thumb}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
      <div class="w-14 h-14 bg-brand-500 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-dark-900 ml-1" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
    </div>
    {difficulty && (
      <span class={`absolute top-2 left-2 tag tag-difficulty-${difficulty} capitalize text-xs`}>{difficulty}</span>
    )}
  </div>
  <div class="p-4 flex flex-col flex-1">
    <h3 class="font-display font-bold text-white group-hover:text-brand-500 transition-colors leading-tight mb-2">{title}</h3>
    <p class="text-gray-400 text-sm flex-1 line-clamp-2 leading-relaxed">{description}</p>
    <div class="flex flex-wrap gap-1 mt-3">
      {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
    </div>
    <div class="flex items-center justify-between mt-3 text-xs text-gray-500">
      <span>{formattedDate}</span>
      {formattedViews && <span>👁 {formattedViews} views</span>}
    </div>
  </div>
</a>
