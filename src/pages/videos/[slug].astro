---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { BASE } from '../../lib/base';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map(v => ({
    params: { slug: v.id.replace(/\.yaml$/, '') },
    props: { video: v },
  }));
}

const { video } = Astro.props;
const { youtubeId, title, description, tags, difficulty, viewCount, publishedAt } = video.data;
const formattedViews = viewCount ? new Intl.NumberFormat().format(viewCount) : null;
const formattedDate = new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const schema = {
  "@type": "VideoObject",
  "@id": `https://ajcreates.dev${BASE}/videos/${video.id.replace(/\.yaml$/, '')}/#video`,
  "name": title,
  "description": description,
  "uploadDate": publishedAt,
  "embedUrl": `https://www.youtube.com/embed/${youtubeId}`,
  "thumbnailUrl": `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`,
  "url": `https://www.youtube.com/watch?v=${youtubeId}`,
  ...(viewCount ? { "interactionStatistic": {
    "@type": "InteractionCounter",
    "interactionType": "https://schema.org/WatchAction",
    "userInteractionCount": viewCount,
  }} : {}),
  "keywords": tags.join(', '),
  "author": { "@id": `https://ajcreates.dev${BASE}/#person` },
};
---

<BaseLayout
  title={title}
  description={description}
  type="video"
  image={`https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`}
  schema={schema}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href={BASE + '/'} class="hover:text-brand-500 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href={BASE + '/videos'} class="hover:text-brand-500 transition-colors">Videos</a>
      <span class="mx-2">›</span>
      <span class="text-gray-300">{title}</span>
    </nav>

    <!-- Video embed -->
    <div class="rounded-2xl overflow-hidden aspect-video bg-dark-700 mb-8 shadow-2xl shadow-black/50">
      <iframe
        src={`https://www.youtube.com/embed/${youtubeId}`}
        title={title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>

    <!-- Meta -->
    <div class="flex flex-wrap items-center gap-3 mb-4">
      {difficulty && <span class={`tag tag-difficulty-${difficulty} capitalize`}>{difficulty}</span>}
      <time class="text-gray-500 text-sm" datetime={publishedAt}>{formattedDate}</time>
      {formattedViews && <span class="text-gray-500 text-sm">👁 {formattedViews} views</span>}
    </div>

    <h1 class="font-display text-4xl font-black text-white mb-4">{title}</h1>
    <p class="text-lg text-gray-400 leading-relaxed mb-6">{description}</p>

    <div class="flex flex-wrap gap-2 mb-8">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>

    <!-- CTA -->
    <div class="flex flex-wrap gap-4 pt-8 border-t border-dark-700">
      <a
        href={`https://www.youtube.com/watch?v=${youtubeId}`}
        target="_blank"
        rel="noopener"
        class="btn-primary"
      >
        Watch on YouTube ↗
      </a>
      <a href={BASE + '/videos'} class="btn-secondary">← All Videos</a>
    </div>
  </div>
</BaseLayout>
