---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BASE } from '../lib/base';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
    <div class="text-8xl mb-6 select-none">🃏</div>
    <h1 class="font-display text-5xl font-black text-white mb-4">404</h1>
    <h2 class="font-display text-2xl font-bold text-gray-300 mb-4">That card's not in the deck</h2>
    <p class="text-gray-400 max-w-md mb-10">
      The page you're looking for has vanished — like a card forced into an impossible location.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={BASE + '/'} class="btn-primary">Back to Home</a>
      <a href={BASE + '/tutorials'} class="btn-secondary">Browse Tutorials</a>
    </div>
  </div>
</BaseLayout>
