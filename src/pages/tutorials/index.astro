---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TutorialCard from '../../components/TutorialCard.astro';
import { getCollection } from 'astro:content';
import { BASE } from '../../lib/base';

const tutorials = (await getCollection('tutorials'))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const difficulties = ['beginner', 'intermediate', 'advanced'];
const grouped = Object.fromEntries(
  difficulties.map(d => [d, tutorials.filter(t => t.data.difficulty === d)])
);

const schema = {
  "@type": "CollectionPage",
  "@id": `https://ajcreates.dev${BASE}/tutorials/#webpage`,
  "url": `https://ajcreates.dev${BASE}/tutorials/`,
  "name": "Card Magic Tutorials",
  "description": "Step-by-step card magic tutorials for all skill levels — from beginner to advanced.",
  "isPartOf": { "@id": `https://ajcreates.dev${BASE}/#website` },
};
---

<BaseLayout
  title="Tutorials"
  description="Step-by-step card magic tutorials for all skill levels. Learn beginner flourishes, intermediate controls, and advanced sleight of hand."
  schema={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="font-display text-5xl font-black text-white mb-4">Card Magic Tutorials</h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Step-by-step guides for every skill level. Pick where you are and start learning.
      </p>
    </div>

    <!-- By difficulty -->
    {difficulties.map(d => grouped[d].length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="font-display text-2xl font-bold text-white capitalize">{d}</h2>
          <span class={`tag tag-difficulty-${d} capitalize`}>{d}</span>
          <div class="flex-1 h-px bg-dark-700"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {grouped[d].map(t => (
            <TutorialCard
              id={t.id}
              title={t.data.title}
              description={t.data.description}
              tags={t.data.tags}
              difficulty={t.data.difficulty}
              slug={t.slug}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
