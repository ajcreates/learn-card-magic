---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { BASE } from '../../lib/base';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, tags, publishedAt, readTime } = post.data;

const schema = {
  "@type": "BlogPosting",
  "@id": `https://ajcreates.dev${BASE}/blog/${post.slug}/#article`,
  "headline": title,
  "description": description,
  "datePublished": publishedAt,
  "url": `https://ajcreates.dev${BASE}/blog/${post.slug}/`,
  "author": { "@id": `https://ajcreates.dev${BASE}/#person` },
  "publisher": { "@id": `https://ajcreates.dev${BASE}/#person` },
  "isPartOf": { "@id": `https://ajcreates.dev${BASE}/#website` },
  "keywords": tags.join(', '),
};
---

<BaseLayout title={title} description={description} type="article" schema={schema}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href={BASE + '/'} class="hover:text-brand-500 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href={BASE + '/blog'} class="hover:text-brand-500 transition-colors">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-gray-300">{title}</span>
    </nav>

    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-black text-white mb-4 leading-tight">{title}</h1>
      <p class="text-xl text-gray-400 leading-relaxed mb-6">{description}</p>
      <div class="flex items-center gap-4 text-sm text-gray-500 border-t border-dark-700 pt-6">
        <time datetime={publishedAt}>
          {new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {readTime && <span>· {readTime} min read</span>}
      </div>
    </header>

    <article class="prose prose-invert max-w-none
      prose-headings:font-display prose-headings:text-white
      prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-gray-300 prose-p:leading-relaxed
      prose-a:text-brand-500 prose-a:no-underline hover:prose-a:text-brand-400
      prose-strong:text-white
      prose-blockquote:border-brand-500 prose-blockquote:bg-dark-800/50 prose-blockquote:rounded-r-lg
      prose-code:text-brand-400 prose-code:bg-dark-700 prose-code:px-1.5 prose-code:rounded
      prose-ul:text-gray-300 prose-ol:text-gray-300
      prose-hr:border-dark-700
    ">
      <Content />
    </article>

    <div class="mt-16 pt-8 border-t border-dark-700">
      <a href={BASE + '/blog'} class="btn-secondary">← Back to Blog</a>
    </div>
  </div>
</BaseLayout>
